=comment Package: Gtk4, C-Source: gesturesingle
use v6.d;

#TL:1:Gnome::Gtk4::GestureSingle:
#-------------------------------------------------------------------------------
#--[Module Imports]-------------------------------------------------------------
#-------------------------------------------------------------------------------

use Test;
use NativeCall;


#use Gnome::Gdk4::N-EventSequence:api<2>;
#use Gnome::Gdk4::T-events:api<2>;
use Gnome::Gtk4::GestureClick:api<2>;
#use Gnome::Gtk4::GestureSingle:api<2>;
use Gnome::N::GlibToRakuTypes:api<2>;
use Gnome::N::N-Object:api<2>;
use Gnome::N::NativeLib:api<2>;
use Gnome::N::X:api<2>;

#-------------------------------------------------------------------------------
#--[Test preparation]-----------------------------------------------------------
#-------------------------------------------------------------------------------

#Gnome::N::debug(:on);
# GestureClick inherits from GestureSingle
my Gnome::Gtk4::GestureClick $gestureclick;

#-------------------------------------------------------------------------------
#-------------------------------------------------------------------------------
#-------------------------------------------------------------------------------
# set environment variable 'raku-test-all' if rest must be tested too.
unless %*ENV<raku_test_all>:exists {
  done-testing;
  exit;
}

#-------------------------------------------------------------------------------
subtest 'Method tests', {
  $gestureclick .= new-gestureclick();
  with $gestureclick {
    my Bool $exclusive;
    my UInt $button;
    my Bool $touch-only;

    #TM:1:set-button()
    $button = 2;
    .set-button($button);
    #TM:1:get-button()
    is .get-button(),  $button, '.set-button() / .get-button()';

    #TM:1:set-exclusive()
    $exclusive = True;
    .set-exclusive( $exclusive);
    #TM:1:get-exclusive()
    is .get-exclusive(),  $exclusive, '.set-exclusive() / .get-exclusive()';

    #TM:1:get-current-button(). No events yet -> 0
    is .get-current-button(), 0, '.get-current-button()';

    #TM:1:set-touch-only()
    $touch-only = True;
    .set-touch-only( $touch-only);
    #TM:1:get-touch-only()
    is .get-touch-only(),  $touch-only, '.set-touch-only() / .get-touch-only()';

    #TM:0:get-current-sequence(), No events yet -> undefined
    my N-Object $no = .get-current-sequence();
    ok !$no, '.get-current-sequence()';
  }
};

#-------------------------------------------------------------------------------
done-testing;

=finish

#-------------------------------------------------------------------------------
subtest 'Signals …', {
  use Gnome::Gtk3::Main;

  my Gnome::Gtk3::Main $main .= new;

  class SignalHandlers {
    has Bool $!signal-processed = False;

    method … (
      'any-args',
      Gnome::Gtk4::GestureSingle() :$_native-object, gulong :$_handler-id
      # --> …
    ) {

      isa-ok $_native-object, Gnome::Gtk4::GestureSingle;
      $!signal-processed = True;
    }

    method signal-emitter ( Gnome::Gtk4::GestureSingle :$_widget --> Str ) {

      while $main.gtk-events-pending() { $main.iteration-do(False); }

      $_widget.emit-by-name(
        'signal',
      #  'any-args',
      #  :return-type(int32),
      #  :parameters([int32,])
      );
      is $!signal-processed, True, ''…' signal processed';

      while $main.gtk-events-pending() { $main.iteration-do(False); }

      #$!signal-processed = False;
      #$_widget.emit-by-name(
      #  'signal',
      #  'any-args',
      #  :return-type(int32),
      #  :parameters([int32,])
      #);
      #is $!signal-processed, True, ''…' signal processed';

      while $main.gtk-events-pending() { $main.iteration-do(False); }
      sleep(0.4);
      $main.gtk-main-quit;

      'done'
    }
  }

  my Gnome::Gtk4::GestureSingle $gesturesingle .= new;

  #my Gnome::Gtk3::Window $w .= new;
  #$w.add($m);

  my SignalHandlers $sh .= new;
  $gesturesingle.register-signal( $sh, 'method', 'signal');

  my Promise $p = $i.start-thread(
    $sh, 'signal-emitter',
    # :!new-context,
    # :start-time(now + 1)
  );

  is $main.gtk-main-level, 0, "loop level 0";
  $main.gtk-main;
  #is $main.gtk-main-level, 0, "loop level is 0 again";

  is $p.result, 'done', 'emitter finished';
}

